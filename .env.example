# 复制为 .env（本地）或在 Vercel 项目设置里配置这些环境变量
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# 可选：解读用的模型。质量优先用 claude-opus-4-8，性价比用 claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# 可选：Supabase 数据记录（不配则不记录，不影响主功能）
# SUPABASE_KEY 用 service_role key（只放服务器端，别暴露给前端）
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...service_role...
